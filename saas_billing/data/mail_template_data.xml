<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--
            Odoo 18 mail templates use Inline-Render QWeb: {{ python_expr }} for inline output,
            and the old Jinja `${...}` syntax is removed. All templates below use the new syntax.
            Pay links route exclusively through SSLCommerz via /saas/subscription/<id>/pay_invoice.
        -->

        <!-- Template: Invoice Generated -->
        <record id="email_template_invoice_generated" model="mail.template">
            <field name="name">SaaS Invoice Generated</field>
            <field name="model_id" ref="saas_subscription.model_saas_subscription"/>
            <field name="subject">Your SaaS Invoice is Ready — {{ object.name }}</field>
            <field name="email_from">{{ (object.company_id.email or user.email) or '' }}</field>
            <field name="email_to">{{ object.partner_id.email }}</field>
            <field name="lang">{{ object.partner_id.lang }}</field>
            <field name="body_html" type="html">
                <div style="font-family: Arial, sans-serif; max-width: 600px;">
                    <h3>Hello <t t-out="object.partner_id.name or ''"/>,</h3>
                    <p>A new invoice has been issued for your subscription
                       <strong t-out="object.name or ''"/>.</p>
                    <t t-set="invoice" t-value="ctx.get('invoice_id') or (object.invoice_ids and object.invoice_ids[0])"/>
                    <t t-if="invoice">
                        <p><strong>Amount:</strong>
                           <t t-out="invoice.amount_total"/>
                           <t t-out="invoice.currency_id.symbol or ''"/></p>
                        <p><strong>Due Date:</strong>
                           <t t-out="invoice.invoice_date_due"/></p>
                        <p>
                            <a t-attf-href="{{ object.get_base_url() }}/saas/subscription/{{ object.id }}/pay_invoice?invoice_id={{ invoice.id }}"
                               style="background-color:#4CAF50;color:white;padding:10px 18px;text-decoration:none;border-radius:5px;display:inline-block;">
                                Pay Now via SSLCommerz
                            </a>
                        </p>
                    </t>
                    <p style="color:#666;font-size:12px;margin-top:18px;">
                        You can also view all your invoices at
                        <a t-attf-href="{{ object.get_base_url() }}/my/subscriptions/{{ object.id }}">your subscription page</a>.
                    </p>
                </div>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>

        <!-- Template: Dunning Reminder 1 (Day 2) -->
        <record id="email_template_dunning_reminder_1" model="mail.template">
            <field name="name">SaaS Payment Reminder - Day 2</field>
            <field name="model_id" ref="saas_subscription.model_saas_subscription"/>
            <field name="subject">Payment Reminder: Your SaaS invoice is due — {{ object.name }}</field>
            <field name="email_from">{{ (object.company_id.email or user.email) or '' }}</field>
            <field name="email_to">{{ object.partner_id.email }}</field>
            <field name="lang">{{ object.partner_id.lang }}</field>
            <field name="body_html" type="html">
                <div style="font-family: Arial, sans-serif; max-width: 600px;">
                    <h3>Friendly Payment Reminder</h3>
                    <p>Dear <t t-out="object.partner_id.name or ''"/>,</p>
                    <p>This is a friendly reminder that your SaaS subscription invoice is due.</p>
                    <t t-set="invoice" t-value="ctx.get('invoice_id')"/>
                    <t t-if="invoice">
                        <p><strong>Invoice:</strong> <t t-out="invoice.name"/> —
                           <t t-out="invoice.amount_residual"/>
                           <t t-out="invoice.currency_id.symbol or ''"/></p>
                        <p>
                            <a t-attf-href="{{ object.get_base_url() }}/saas/subscription/{{ object.id }}/pay_invoice?invoice_id={{ invoice.id }}"
                               style="background-color:#4CAF50;color:white;padding:10px 18px;text-decoration:none;border-radius:5px;display:inline-block;">
                                Pay Now via SSLCommerz
                            </a>
                        </p>
                    </t>
                </div>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>

        <!-- Template: Dunning Reminder 2 (Day 5 + Late Fee) -->
        <record id="email_template_dunning_reminder_2" model="mail.template">
            <field name="name">SaaS Payment Reminder - Day 5</field>
            <field name="model_id" ref="saas_subscription.model_saas_subscription"/>
            <field name="subject">Urgent: Your SaaS payment is overdue — {{ object.name }}</field>
            <field name="email_from">{{ (object.company_id.email or user.email) or '' }}</field>
            <field name="email_to">{{ object.partner_id.email }}</field>
            <field name="lang">{{ object.partner_id.lang }}</field>
            <field name="body_html" type="html">
                <div style="font-family: Arial, sans-serif; max-width: 600px;">
                    <h3 style="color:#ff9800;">Urgent Payment Required</h3>
                    <p>Dear <t t-out="object.partner_id.name or ''"/>,</p>
                    <p>Your payment is now <strong>5 days overdue</strong>. A late fee has been applied.</p>
                    <t t-set="invoice" t-value="ctx.get('invoice_id')"/>
                    <t t-if="invoice">
                        <p>
                            <a t-attf-href="{{ object.get_base_url() }}/saas/subscription/{{ object.id }}/pay_invoice?invoice_id={{ invoice.id }}"
                               style="background-color:#ff9800;color:white;padding:10px 18px;text-decoration:none;border-radius:5px;display:inline-block;">
                                Pay Now to Avoid Suspension
                            </a>
                        </p>
                    </t>
                </div>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>

        <!-- Template: Final Warning (Day 8) -->
        <record id="email_template_dunning_final_warning" model="mail.template">
            <field name="name">SaaS Final Warning - Day 8</field>
            <field name="model_id" ref="saas_subscription.model_saas_subscription"/>
            <field name="subject">FINAL NOTICE: Your SaaS service will be suspended — {{ object.name }}</field>
            <field name="email_from">{{ (object.company_id.email or user.email) or '' }}</field>
            <field name="email_to">{{ object.partner_id.email }}</field>
            <field name="lang">{{ object.partner_id.lang }}</field>
            <field name="body_html" type="html">
                <div style="font-family: Arial, sans-serif; max-width: 600px;">
                    <h3 style="color:#d9534f;">Final Notice — 24 Hour Deadline</h3>
                    <p>Dear <t t-out="object.partner_id.name or ''"/>,</p>
                    <p><strong>Your SaaS service will be suspended in 24 hours</strong> if payment is not received.</p>
                    <t t-set="invoice" t-value="ctx.get('invoice_id')"/>
                    <t t-if="invoice">
                        <p>
                            <a t-attf-href="{{ object.get_base_url() }}/saas/subscription/{{ object.id }}/pay_invoice?invoice_id={{ invoice.id }}"
                               style="background-color:#d9534f;color:white;padding:10px 18px;text-decoration:none;border-radius:5px;display:inline-block;">
                                Pay Now to Avoid Suspension
                            </a>
                        </p>
                    </t>
                </div>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>

        <!-- Template: Suspension Notice -->
        <record id="email_template_dunning_suspension" model="mail.template">
            <field name="name">SaaS Service Suspended</field>
            <field name="model_id" ref="saas_subscription.model_saas_subscription"/>
            <field name="subject">Your SaaS service has been suspended — {{ object.name }}</field>
            <field name="email_from">{{ (object.company_id.email or user.email) or '' }}</field>
            <field name="email_to">{{ object.partner_id.email }}</field>
            <field name="lang">{{ object.partner_id.lang }}</field>
            <field name="body_html" type="html">
                <div style="font-family: Arial, sans-serif; max-width: 600px;">
                    <h3 style="color:#d9534f;">Service Suspended</h3>
                    <p>Dear <t t-out="object.partner_id.name or ''"/>,</p>
                    <p>Your SaaS service has been suspended due to non-payment.</p>
                    <p>To restore access, please pay the outstanding amount.
                       Your service will be automatically reactivated upon payment.</p>
                    <p><strong>Your data will be retained for 14 days before permanent deletion.</strong></p>
                    <p>
                        <a t-attf-href="{{ object.get_base_url() }}/my/subscriptions/{{ object.id }}"
                           style="background-color:#4CAF50;color:white;padding:10px 18px;text-decoration:none;border-radius:5px;display:inline-block;">
                            Restore Service
                        </a>
                    </p>
                </div>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>
    </data>
</odoo>
