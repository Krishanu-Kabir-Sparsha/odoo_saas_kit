<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron: System Health Check -->
        <record id="cron_system_health_check" model="ir.cron">
            <field name="name">System Health Check</field>
            <field name="model_id" ref="model_saas_system_health"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_health()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active">True</field>
        </record>

        <!-- Email Template: Critical Alert -->
        <record id="email_template_critical_alert" model="mail.template">
            <field name="name">SaaS Critical System Alert</field>
            <field name="model_id" ref="model_saas_system_health"/>
            <field name="subject">[CRITICAL] SaaS System Health Alert</field>
            <field name="email_from">${object.create_uid.company_id.email or ''}</field>
            <field name="email_to">${object.create_uid.company_id.email or ''}</field>
            <field name="body_html"><![CDATA[
                <div style="font-family: Arial, sans-serif;">
                    <h3 style="color: #d9534f;">Critical System Alert</h3>
                    <p><strong>Time:</strong> ${object.check_time}</p>
                    <p><strong>Status:</strong> ${object.status}</p>
                    <p><strong>Warnings:</strong></p>
                    <pre>${object.warnings}</pre>
                    <p><strong>Metrics:</strong></p>
                    <ul>
                        <li>Disk Usage: ${object.disk_usage}%</li>
                        <li>Memory Usage: ${object.memory_usage}%</li>
                        <li>CPU Usage: ${object.cpu_usage}%</li>
                        <li>Pending Provisioning: ${object.pending_provisioning}</li>
                        <li>Failed Invoices: ${object.failed_invoices}</li>
                    </ul>
                    <p>Please take immediate action.</p>
                </div>
            ]]></field>
        </record>
    </data>
</odoo>