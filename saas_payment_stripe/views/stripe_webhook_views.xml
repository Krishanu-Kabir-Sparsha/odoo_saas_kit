<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Webhook Log Tree View -->
    <record id="view_stripe_webhook_tree" model="ir.ui.view">
        <field name="name">stripe.webhook.tree</field>
        <field name="model">stripe.webhook</field>
        <field name="arch" type="xml">
            <list>
                <field name="created_at"/>
                <field name="event_type"/>
                <field name="processed" widget="boolean"/>
                <field name="processed_at"/>
                <field name="error_message" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Webhook Log Form View -->
    <record id="view_stripe_webhook_form" model="ir.ui.view">
        <field name="name">stripe.webhook.form</field>
        <field name="model">stripe.webhook</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="event_id"/>
                            <field name="event_type"/>
                            <field name="processed"/>
                        </group>
                        <group>
                            <field name="created_at"/>
                            <field name="processed_at"/>
                        </group>
                    </group>
                    <group string="Error" invisible="not error_message">
                        <field name="error_message" nolabel="1"/>
                    </group>
                    <group string="Payload">
                        <field name="payload" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Stripe Configuration Form -->
    <record id="view_stripe_config_form" model="ir.ui.view">
        <field name="name">stripe.config.form</field>
        <field name="model">stripe.config</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="alert alert-info">
                        <strong>Stripe Configuration</strong><br/>
                        Enter your Stripe API keys. Get them from your Stripe Dashboard.
                    </div>
                    <group>
                        <field name="secret_key" password="True" required="1"/>
                        <field name="publishable_key" required="1"/>
                        <field name="webhook_secret" password="True"/>
                        <field name="webhook_url"/>
                    </group>
                    <footer>
                        <button name="action_save_config" type="object" string="Save and Test" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_stripe_webhook" model="ir.actions.act_window">
        <field name="name">Stripe Webhook Logs</field>
        <field name="res_model">stripe.webhook</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_stripe_config" model="ir.actions.act_window">
        <field name="name">Stripe Configuration</field>
        <field name="res_model">stripe.config</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menus -->
    <menuitem id="menu_saas_payment" name="Payment" parent="saas_package.menu_saas_root" sequence="50" groups="saas_package.group_saas_manager"/>
    <menuitem id="menu_stripe_webhook" name="Stripe Webhook Logs" parent="menu_saas_payment" action="action_stripe_webhook" sequence="10"/>
    <menuitem id="menu_stripe_config" name="Stripe Configuration" parent="menu_saas_payment" action="action_stripe_config" sequence="20"/>
</odoo>