<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Payment Success Page -->
    <template id="payment_success" name="Payment Success">
        <t t-call="portal.portal_layout">
            <div class="container mt-5">
                <div class="alert alert-success text-center">
                    <h2>Payment Successful!</h2>
                    <p>Your payment has been processed successfully.</p>
                    <p>Your SaaS instance is being provisioned. You will receive an email with access details shortly.</p>
                    <a href="/my/subscriptions" class="btn btn-primary mt-3">View My Subscriptions</a>
                </div>
            </div>
        </t>
    </template>

    <!-- Payment Cancel Page -->
    <template id="payment_cancel" name="Payment Cancel">
        <t t-call="portal.portal_layout">
            <div class="container mt-5">
                <div class="alert alert-warning text-center">
                    <h2>Payment Cancelled</h2>
                    <p>Your payment was cancelled. No charges have been made.</p>
                    <a href="/saas/packages" class="btn btn-primary mt-3">Back to Packages</a>
                </div>
            </div>
        </t>
    </template>

    <!-- Payment Form (for single invoice payment) -->
    <template id="payment_form" name="Payment Form">
        <t t-call="portal.portal_layout">
            <div class="container mt-5">
                <div class="row justify-content-center">
                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-header">
                                <h4>Pay Invoice</h4>
                            </div>
                            <div class="card-body">
                                <p><strong>Subscription:</strong> <t t-esc="subscription.name"/></p>
                                <p><strong>Invoice:</strong> <t t-esc="invoice.name"/></p>
                                <p><strong>Amount:</strong> <t t-esc="invoice.amount_total"/> <t t-esc="invoice.currency_id.symbol"/></p>
                                
                                <div id="card-element"></div>
                                <div id="card-errors" class="text-danger mt-2"></div>
                                
                                <button id="submit-payment" class="btn btn-success btn-block mt-3">Pay Now</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <script src="https://js.stripe.com/v3/"></script>
            <script>
                var stripe = Stripe('<t t-esc="publishable_key"/>');
                var elements = stripe.elements();
                var card = elements.create('card');
                card.mount('#card-element');
                
                var form = document.getElementById('submit-payment');
                form.addEventListener('click', function(ev) {
                    stripe.confirmCardPayment('<t t-esc="client_secret"/>', {
                        payment_method: {
                            card: card,
                        }
                    }).then(function(result) {
                        if (result.error) {
                            var errorElement = document.getElementById('card-errors');
                            errorElement.textContent = result.error.message;
                        } else {
                            window.location.href = '/saas/payment/success';
                        }
                    });
                });
            </script>
        </t>
    </template>
</odoo>