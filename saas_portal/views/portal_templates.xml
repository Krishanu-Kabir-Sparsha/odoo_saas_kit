<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Portal My Subscriptions -->
    <template id="portal_my_subscriptions" name="My Subscriptions">
        <t t-call="portal.portal_layout">
            <div class="container">
                <t t-if="error">
                    <div class="alert alert-danger"><t t-esc="error"/></div>
                </t>
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <h3 class="mb-0">My Subscriptions</h3>
                                <a href="/saas/packages" class="btn btn-primary btn-sm">New Subscription</a>
                            </div>
                            <div class="card-body">
                                <t t-if="subscriptions">
                                    <div class="table-responsive">
                                        <table class="table table-striped">
                                            <thead>
                                                <tr>
                                                    <th>Reference</th>
                                                    <th>Package</th>
                                                    <th>Status</th>
                                                    <th>Start Date</th>
                                                    <th>Next Invoice</th>
                                                    <th>Actions</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr t-foreach="subscriptions" t-as="sub">
                                                    <td><t t-esc="sub.name"/></td>
                                                    <td><t t-esc="sub.package_id.name"/></td>
                                                    <td>
                                                        <span t-attf-class="badge bg-#{
                                                            'success' if sub.state == 'active' else
                                                            'danger' if sub.state == 'suspended' else
                                                            'warning' if sub.state == 'pending' else
                                                            'secondary'
                                                        }">
                                                            <t t-esc="sub.state"/>
                                                        </span>
                                                        <t t-if="sub.is_trial">
                                                            <span class="badge bg-warning text-dark ms-1">Trial · <t t-esc="sub.trial_days_left"/>d</span>
                                                        </t>
                                                    </td>
                                                    <td><t t-esc="sub.date_start"/></td>
                                                    <td><t t-esc="sub.date_next_invoice"/></td>
                                                    <td>
                                                        <a t-attf-href="/my/subscriptions/{{sub.id}}" class="btn btn-sm btn-info">View</a>
                                                        <t t-if="sub.state == 'active' and sub.tenant_url">
                                                            <a t-attf-href="{{sub.tenant_url}}" target="_blank" class="btn btn-sm btn-success">Access</a>
                                                        </t>
                                                        <t t-elif="sub.state == 'active' and not sub.tenant_url">
                                                            <button type="button" class="btn btn-sm btn-secondary" disabled="disabled"
                                                                    title="Your instance is being set up">
                                                                <span class="fa fa-spinner fa-spin me-1"/>Provisioning…
                                                            </button>
                                                        </t>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                    <t t-call="portal.pager"/>
                                    <t t-if="has_provisioning">
                                        <script type="text/javascript">
                                            // Auto-refresh the list while any instance is still provisioning.
                                            setTimeout(function () { window.location.reload(); }, 20000);
                                        </script>
                                    </t>
                                </t>
                                <t t-else="">
                                    <div class="text-center py-5">
                                        <span class="fa fa-cloud fa-3x text-muted mb-3"/>
                                        <h4>No Subscriptions Yet</h4>
                                        <a href="/saas/packages" class="btn btn-primary mt-3">Browse Packages</a>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Portal Subscription Detail -->
    <template id="portal_subscription_detail" name="Subscription Detail">
        <t t-call="portal.portal_layout">
            <div class="container">
                <div class="row">
                    <div class="col-12">
                        <div class="mb-3">
                            <a href="/my/subscriptions" class="text-muted">Back to Subscriptions</a>
                        </div>

                        <div class="card">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <h3 class="mb-0">Subscription <t t-esc="subscription.name"/></h3>
                                <div class="d-flex gap-2">
                                    <t t-if="subscription.is_trial and subscription.state in ('active', 'suspended')">
                                        <a t-attf-href="/saas/subscription/{{subscription.id}}/subscribe" class="btn btn-success btn-sm">
                                            <span class="fa fa-star me-1"/>Subscribe now
                                        </a>
                                    </t>
                                    <t t-if="subscription.state == 'active' and not subscription.is_trial and subscription.tenant_url">
                                        <a t-attf-href="/my/subscriptions/{{subscription.id}}/upgrade" class="btn btn-primary btn-sm">
                                            <span class="fa fa-arrow-up me-1"/>Upgrade Plan
                                        </a>
                                    </t>
                                    <t t-if="subscription.state == 'active'">
                                        <button type="button" class="btn btn-danger btn-sm" data-bs-toggle="modal" data-bs-target="#cancelModal">Cancel</button>
                                    </t>
                                    <t t-if="subscription.state == 'canceled'">
                                        <form method="post" t-attf-action="/my/subscriptions/{{subscription.id}}/reactivate">
                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                            <button type="submit" class="btn btn-warning btn-sm">Reactivate</button>
                                        </form>
                                    </t>
                                </div>
                            </div>
                            <div class="card-body">
                                <t t-if="message"><div class="alert alert-success"><t t-esc="message"/></div></t>
                                <t t-if="error"><div class="alert alert-danger"><t t-esc="error"/></div></t>
                                <t t-if="subscription.is_trial">
                                    <div class="alert alert-warning d-flex justify-content-between align-items-center">
                                        <span><span class="fa fa-clock-o me-1"/>You're on a free trial — <strong><t t-esc="subscription.trial_days_left"/> days left</strong>. Subscribe to keep your workspace after it ends.</span>
                                        <a t-attf-href="/saas/subscription/{{subscription.id}}/subscribe" class="btn btn-success btn-sm">Subscribe now</a>
                                    </div>
                                </t>
                                <div class="row">
                                    <div class="col-md-6">
                                        <h5>Subscription Details</h5>
                                        <table class="table table-sm">
                                            <tr><th>Package:</th><td><t t-esc="subscription.package_id.name"/></td></tr>
                                            <tr><th>Billing Cycle:</th><td><t t-esc="subscription.billing_cycle"/></td></tr>
                                            <tr><th>Status:</th><td>
                                                <span class="badge bg-info"><t t-esc="subscription.state"/></span>
                                                <t t-if="subscription.is_trial">
                                                    <span class="badge bg-warning text-dark ms-1">Trial — <t t-esc="subscription.trial_days_left"/> days left</span>
                                                </t>
                                            </td></tr>
                                            <tr><th>Start Date:</th><td><t t-esc="subscription.date_start"/></td></tr>
                                            <tr><th>Next Invoice:</th><td><t t-esc="subscription.date_next_invoice"/></td></tr>
                                        </table>
                                    </div>
                                    <div class="col-md-6">
                                        <h5>Access Information</h5>
                                        <t t-if="subscription.tenant_url">
                                            <p><strong>Tenant URL:</strong> <a t-attf-href="{{subscription.tenant_url}}" target="_blank"><t t-esc="subscription.tenant_url"/></a></p>
                                            <p><strong>Username:</strong> <t t-esc="subscription.partner_id.email or 'your registered email'"/></p>
                                            <p><em>Check your email for the password.</em></p>
                                            <a t-attf-href="{{subscription.tenant_url}}" target="_blank"
                                               class="btn btn-success btn-sm mt-1">
                                                <span class="fa fa-external-link me-1"/>Access Your Instance
                                            </a>
                                        </t>
                                        <t t-elif="subscription.state == 'provisioning_failed'">
                                            <div class="alert alert-danger mb-0">
                                                Provisioning failed. Please contact support and we'll get your instance up shortly.
                                            </div>
                                        </t>
                                        <t t-else="">
                                            <p class="text-muted mb-1">
                                                <span class="fa fa-spinner fa-spin me-1"/>Your instance is being provisioned…
                                            </p>
                                            <small class="text-muted">This can take a few minutes — this page updates automatically when it's ready.</small>
                                            <script type="text/javascript">
                                                (function () {
                                                    var subId = <t t-esc="subscription.id"/>;
                                                    var tries = 0;
                                                    var timer = setInterval(function () {
                                                        tries += 1;
                                                        if (tries > 120) { clearInterval(timer); return; }
                                                        fetch('/saas/activation/status/' + subId + '/json')
                                                            .then(function (r) { return r.json(); })
                                                            .then(function (d) {
                                                                if ((d.tenant_url &amp;&amp; d.tenant_url.length) || d.is_failed) {
                                                                    clearInterval(timer);
                                                                    window.location.reload();
                                                                }
                                                            })
                                                            .catch(function () {});
                                                    }, 5000);
                                                })();
                                            </script>
                                        </t>
                                    </div>
                                </div>

                                <hr/>

                                <h5>Invoice History</h5>
                                <div class="table-responsive">
                                    <table class="table table-sm">
                                        <thead>
                                            <tr>
                                                <th>Invoice Number</th>
                                                <th>Date</th>
                                                <th>Amount</th>
                                                <th>Status</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr t-foreach="invoices" t-as="inv">
                                                <td><t t-esc="inv.name"/></td>
                                                <td><t t-esc="inv.invoice_date"/></td>
                                                <td><t t-esc="inv.amount_total"/> <t t-esc="inv.currency_id.symbol"/></td>
                                                <td>
                                                    <span t-attf-class="badge bg-#{
                                                        'success' if inv.payment_state == 'paid' else
                                                        'danger' if inv.payment_state == 'not_paid' else
                                                        'warning'
                                                    }">
                                                        <t t-esc="inv.payment_state"/>
                                                    </span>
                                                </td>
                                                <td>
                                                    <a t-attf-href="/my/invoices/{{inv.id}}/pdf" target="_blank" class="btn btn-sm btn-outline-info">PDF</a>
                                                    <t t-if="inv.payment_state != 'paid' and subscription.state != 'canceled'">
                                                        <a t-attf-href="/saas/subscription/{{subscription.id}}/pay_invoice?invoice_id={{inv.id}}" class="btn btn-sm btn-success">Pay</a>
                                                    </t>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>

                                <hr/>

                                <h5>Points Activity</h5>
                                <div class="row mb-3">
                                    <div class="col-md-4">
                                        <div class="text-center p-2 bg-info text-white rounded">
                                            <strong>Available Points</strong><br/>
                                            <h3><t t-esc="points_balance"/></h3>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="text-center p-2 bg-warning text-white rounded">
                                            <strong>Points Value</strong><br/>
                                            <h3><t t-esc="points_value"/></h3>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="text-center p-2 bg-secondary text-white rounded">
                                            <strong>Min to Redeem</strong><br/>
                                            <h3><t t-esc="min_points"/></h3>
                                        </div>
                                    </div>
                                </div>

                                <div class="table-responsive">
                                    <table class="table table-sm">
                                        <thead>
                                            <tr>
                                                <th>Date</th>
                                                <th>Type</th>
                                                <th>Points</th>
                                                <th>Description</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr t-foreach="points_transactions" t-as="trans">
                                                <td><t t-esc="trans.date"/></td>
                                                <td><t t-esc="trans.transaction_type"/></td>
                                                <td><t t-esc="trans.points"/></td>
                                                <td><t t-esc="trans.description"/></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Cancel Modal -->
            <div class="modal fade" id="cancelModal" tabindex="-1">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <form method="post" t-attf-action="/my/subscriptions/{{subscription.id}}/cancel">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <div class="modal-header">
                                <h5 class="modal-title">Cancel Subscription</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <p>Are you sure you want to cancel this subscription?</p>
                                <p><strong>What happens next:</strong></p>
                                <ul>
                                    <li>Your service will be immediately deactivated</li>
                                    <li>Your data will be retained for 30 days</li>
                                    <li>After 30 days, your data will be permanently deleted</li>
                                    <li>You can reactivate within 30 days by contacting support</li>
                                </ul>
                                <div class="mb-3">
                                    <label>Reason (optional)</label>
                                    <textarea name="reason" class="form-control" rows="2" placeholder="Tell us why you're cancelling..."></textarea>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                <button type="submit" class="btn btn-danger">Confirm Cancellation</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Portal My Invoices -->
    <template id="portal_my_invoices" name="My Invoices">
        <t t-call="portal.portal_layout">
            <div class="container">
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-header">
                                <h3 class="mb-0">My Invoices</h3>
                            </div>
                            <div class="card-body">
                                <t t-if="invoices">
                                    <div class="table-responsive">
                                        <table class="table table-striped">
                                            <thead>
                                                <tr>
                                                    <th>Invoice Number</th>
                                                    <th>Date</th>
                                                    <th>Due Date</th>
                                                    <th>Amount</th>
                                                    <th>Status</th>
                                                    <th>Actions</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr t-foreach="invoices" t-as="inv">
                                                    <td><t t-esc="inv.name"/></td>
                                                    <td><t t-esc="inv.invoice_date"/></td>
                                                    <td><t t-esc="inv.invoice_date_due"/></td>
                                                    <td><t t-esc="inv.amount_total"/> <t t-esc="inv.currency_id.symbol"/></td>
                                                    <td>
                                                        <span t-attf-class="badge bg-#{
                                                            'success' if inv.payment_state == 'paid' else
                                                            'danger' if inv.payment_state == 'not_paid' else
                                                            'warning'
                                                        }">
                                                            <t t-esc="inv.payment_state"/>
                                                        </span>
                                                    </td>
                                                    <td>
                                                        <a t-attf-href="/my/invoices/{{inv.id}}/pdf" target="_blank" class="btn btn-sm btn-outline-info">PDF</a>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </t>
                                <t t-else="">
                                    <div class="text-center py-5">
                                        <span class="fa fa-file-invoice fa-3x text-muted"/>
                                        <h4>No Invoices Found</h4>
                                        <p>You don't have any invoices yet.</p>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Portal My Points -->
    <template id="portal_my_points" name="My Points">
        <t t-call="portal.portal_layout">
            <div class="container">
                <div class="row">
                    <div class="col-12">
                        <div class="row mb-4">
                            <div class="col-md-4">
                                <div class="text-center p-4 bg-info text-white rounded">
                                    <h1><t t-esc="points_balance"/></h1>
                                    <p class="mb-0">Available Points</p>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="text-center p-4 bg-success text-white rounded">
                                    <h1><t t-esc="points_value"/></h1>
                                    <p class="mb-0">Approximate Value</p>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="text-center p-4 bg-warning text-white rounded">
                                    <h1><t t-esc="min_points"/></h1>
                                    <p class="mb-0">Minimum to Redeem</p>
                                </div>
                            </div>
                        </div>

                        <div class="card">
                            <div class="card-header">
                                <h4>Transaction History</h4>
                            </div>
                            <div class="card-body">
                                <div class="table-responsive">
                                    <table class="table table-striped">
                                        <thead>
                                            <tr>
                                                <th>Date</th>
                                                <th>Type</th>
                                                <th>Points</th>
                                                <th>Subscription</th>
                                                <th>Description</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr t-foreach="transactions" t-as="trans">
                                                <td><t t-esc="trans.date"/></td>
                                                <td><t t-esc="trans.transaction_type"/></td>
                                                <td><t t-esc="trans.points"/></td>
                                                <td><t t-esc="trans.subscription_id.name"/></td>
                                                <td><t t-esc="trans.description"/></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <div class="alert alert-info mt-3">
                            <strong>How to Earn Points:</strong>
                            <ul class="mb-0">
                                <li>Earn points for every $1 spent on subscriptions</li>
                                <li>Redeem points for discounts on future renewals</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Add "My Subscriptions" to the website account dropdown (top-right,
         the "<user name> ▾" menu next to My Account / Logout). Inserted before
         the Logout link, which reliably carries id="o_logout". -->
    <template id="user_dropdown_my_subscriptions" inherit_id="portal.user_dropdown"
              name="Account Menu: My Subscriptions">
        <xpath expr="//a[@id='o_logout']" position="before">
            <a class="dropdown-item" href="/my/subscriptions">My Subscriptions</a>
        </xpath>
    </template>

    <!-- Upgrade Subscription — pick a higher tier -->
    <template id="portal_subscription_upgrade" name="Upgrade Subscription">
        <t t-call="portal.portal_layout">
            <div class="container">
                <div class="row"><div class="col-12">
                    <div class="mb-3">
                        <a t-attf-href="/my/subscriptions/{{subscription.id}}" class="text-muted">← Back to subscription</a>
                    </div>
                    <t t-if="message"><div class="alert alert-info"><t t-esc="message"/></div></t>
                    <t t-if="error"><div class="alert alert-danger"><t t-esc="error"/></div></t>
                    <div class="card">
                        <div class="card-header"><h3 class="mb-0">Upgrade <t t-esc="subscription.name"/></h3></div>
                        <div class="card-body">
                            <p class="text-muted">
                                You're currently on <strong><t t-esc="subscription.package_id.name"/></strong>
                                (<t t-esc="subscription.billing_plan_label"/>).
                                Upgrading keeps your existing workspace and data — we just add the higher plan's
                                apps now. Choose a term for each plan:
                            </p>
                            <ul class="text-muted small">
                                <li><strong>Keep your current term</strong> → pay only the <strong>prorated tier
                                    difference</strong> for the time left; your renewal date stays the same.</li>
                                <li><strong>Switch to a longer term</strong> → start a fresh term of the new plan,
                                    <strong>credited for what you've already paid</strong> — so you pay the new
                                    term's total minus your remaining balance.</li>
                            </ul>
                            <t t-if="not options">
                                <div class="alert alert-info mb-0">You're already on the highest available plan. 🎉</div>
                            </t>
                            <t t-else="">
                                <div class="row">
                                    <t t-foreach="options" t-as="opt">
                                        <div class="col-md-6 mb-3">
                                            <div class="card h-100 border">
                                                <div class="card-body d-flex flex-column">
                                                    <h5 class="fw-bold mb-1"><t t-esc="opt['package'].name"/></h5>
                                                    <p class="text-muted small mb-2">
                                                        <t t-esc="opt['package'].module_count"/> apps
                                                    </p>
                                                    <form method="post" t-attf-action="/my/subscriptions/{{subscription.id}}/upgrade/pay"
                                                          class="mt-auto saas-upgrade-form" t-att-data-cur="currency_symbol">
                                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                                        <input type="hidden" name="target_package_id" t-att-value="opt['package'].id"/>
                                                        <label class="form-label small fw-semibold mb-1">Choose term</label>
                                                        <select name="duration" class="form-select mb-2 saas-upgrade-duration">
                                                            <t t-foreach="opt['durations']" t-as="d">
                                                                <option t-att-value="d['months']"
                                                                        t-att-data-price="d['price']"
                                                                        t-att-data-monthly="d['monthly']"
                                                                        t-att-selected="'selected' if d['is_current'] else None">
                                                                    <t t-esc="d['label']"/><t t-if="d['is_current']"> — keep current term</t>
                                                                </option>
                                                            </t>
                                                        </select>
                                                        <p class="mb-1 small text-muted">
                                                            Renews at <span class="saas-up-monthly"><t t-esc="currency_symbol"/><t t-esc="'%.2f' % opt['default_monthly']"/></span>/month
                                                        </p>
                                                        <p class="mb-3">Pay now:
                                                            <strong class="text-primary fs-5 saas-up-price"><t t-esc="currency_symbol"/><t t-esc="'%.2f' % opt['default_price']"/></strong>
                                                        </p>
                                                        <button type="submit" class="btn btn-primary w-100">
                                                            Upgrade to <t t-esc="opt['package'].name"/>
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                                <script type="text/javascript">
                                    document.querySelectorAll('.saas-upgrade-duration').forEach(function (sel) {
                                        var form = sel.closest('form');
                                        var cur = form.getAttribute('data-cur') || '৳';
                                        function fmt(n) {
                                            return cur + Number(n).toLocaleString('en-US',
                                                { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                                        }
                                        function update() {
                                            var o = sel.options[sel.selectedIndex];
                                            form.querySelector('.saas-up-price').textContent = fmt(o.getAttribute('data-price'));
                                            form.querySelector('.saas-up-monthly').textContent = fmt(o.getAttribute('data-monthly'));
                                        }
                                        sel.addEventListener('change', update);
                                        update();
                                    });
                                </script>
                            </t>
                        </div>
                    </div>
                </div></div>
            </div>
        </t>
    </template>
</odoo>
