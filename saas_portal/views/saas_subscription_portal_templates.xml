<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Checkout Page -->
    <template id="checkout_page" name="Checkout">
        <t t-call="website.layout">
            <div class="container mt-4 mb-5">
                <div class="row justify-content-center">
                    <div class="col-md-8">
                        <div class="card shadow-sm border-0">
                            <div class="card-header bg-white border-bottom py-3">
                                <h3 class="mb-0 fw-bold">Checkout</h3>
                            </div>
                            <div class="card-body p-4">
                                <t t-if="error">
                                    <div class="alert alert-danger"><t t-esc="error"/></div>
                                </t>
                                <div class="row">
                                    <!-- Order Summary -->
                                    <div class="col-md-7">
                                        <h5 class="fw-semibold mb-3">Order Summary</h5>
                                        <div class="rounded-3 p-3" style="background-color: #f7f8fc; border: 1px solid #e8ecf1;">
                                            <table class="table table-borderless mb-0">
                                                <tbody>
                                                    <tr>
                                                        <td class="text-muted">Package</td>
                                                        <td class="text-end fw-semibold">
                                                            <t t-esc="subscription.package_id.name"/>
                                                        </td>
                                                    </tr>
                                                    <tr>
                                                        <td class="text-muted">Base Price</td>
                                                        <td class="text-end">
                                                            <t t-esc="currency_symbol"/><t t-esc="'%.2f' % base_price"/>/month
                                                        </td>
                                                    </tr>
                                                    <t t-if="discount_pct">
                                                        <tr class="text-success">
                                                            <td>
                                                                Duration Discount (<t t-esc="discount_pct"/>%)
                                                            </td>
                                                            <td class="text-end">
                                                                -<t t-esc="currency_symbol"/><t t-esc="'%.2f' % discount_amt"/>/month
                                                            </td>
                                                        </tr>
                                                    </t>
                                                    <tr>
                                                        <td class="text-muted">Monthly Price</td>
                                                        <td class="text-end fw-semibold">
                                                            <t t-esc="currency_symbol"/><t t-esc="'%.2f' % monthly_price"/>/month
                                                        </td>
                                                    </tr>
                                                    <tr>
                                                        <td class="text-muted">Duration</td>
                                                        <td class="text-end">
                                                            <t t-esc="duration"/> month<t t-if="duration > 1">s</t>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>

                                        <table class="table table-borderless mt-2">
                                            <tbody>
                                                <t t-if="discount_pct">
                                                    <tr class="text-muted">
                                                        <td>Total before discount</td>
                                                        <td class="text-end" style="text-decoration: line-through;">
                                                            <t t-esc="currency_symbol"/><t t-esc="'%.2f' % (base_price * duration)"/>
                                                        </td>
                                                    </tr>
                                                </t>
                                                <tr>
                                                    <td class="text-muted">Subtotal</td>
                                                    <td class="text-end">
                                                        <t t-esc="currency_symbol"/><t t-esc="'%.2f' % subtotal"/>
                                                    </td>
                                                </tr>
                                                <t t-if="setup_fee">
                                                    <tr>
                                                        <td class="text-muted">Setup Fee</td>
                                                        <td class="text-end">
                                                            <t t-esc="currency_symbol"/><t t-esc="'%.2f' % setup_fee"/>
                                                        </td>
                                                    </tr>
                                                </t>
                                                <t t-if="points_discount">
                                                    <tr class="text-success">
                                                        <td>Points Discount (<t t-esc="redeemed_points"/> pts)</td>
                                                        <td class="text-end">
                                                            -<t t-esc="currency_symbol"/><t t-esc="'%.2f' % points_discount"/>
                                                        </td>
                                                    </tr>
                                                </t>
                                                <tr class="border-top">
                                                    <td class="fw-bold fs-5 pt-2">Total</td>
                                                    <td class="text-end fw-bold fs-5 pt-2 text-primary">
                                                        <t t-esc="currency_symbol"/><t t-esc="'%.2f' % total"/>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>

                                        <t t-if="duration > 1">
                                            <div class="text-muted small">
                                                Billed every <t t-esc="duration"/> months
                                            </div>
                                        </t>
                                    </div>

                                    <!-- Payment Section -->
                                    <div class="col-md-5">
                                        <t t-if="points_balance">
                                            <h6 class="fw-semibold mb-2">Apply Points</h6>
                                            <form method="get" action="/saas/checkout" class="mb-3">
                                                <div class="input-group input-group-sm">
                                                    <input type="number" name="redeem_points"
                                                           class="form-control"
                                                           placeholder="Points to redeem"
                                                           min="100"
                                                           t-att-max="points_balance"
                                                           step="100"/>
                                                    <button type="submit"
                                                            class="btn btn-outline-success btn-sm">
                                                        Apply
                                                    </button>
                                                </div>
                                                <small class="form-text text-muted">
                                                    Available: <t t-esc="points_balance"/> points
                                                </small>
                                            </form>
                                            <hr/>
                                        </t>

                                        <form method="post" action="/saas/checkout/pay" target="_top">
                                            <input type="hidden" name="csrf_token"
                                                   t-att-value="request.csrf_token()"/>
                                            <input type="hidden" name="redeem_points_amount"
                                                   t-att-value="redeemed_points"/>
                                            <div class="mb-3 text-start">
                                                <label class="form-label fw-semibold">Company Short Form *</label>
                                                <input type="text" name="company_shortname" class="form-control text-lowercase"
                                                       required="required" minlength="3" maxlength="5"
                                                       pattern="[A-Za-z0-9]{3,5}"
                                                       title="3 to 5 letters or digits — no spaces or symbols"
                                                       t-att-value="suggested_shortname or ''" placeholder="e.g. diu"/>
                                                <small class="form-text text-muted">
                                                    3–5 letters/digits only. Becomes your private workspace address, e.g.
                                                    <strong><t t-esc="suggested_shortname or 'diu'"/>.<t t-esc="base_domain or 'perfecthr.net'"/></strong>
                                                </small>
                                            </div>
                                            <button type="submit"
                                                    class="btn btn-primary btn-lg w-100 rounded-pill fw-semibold"
                                                    style="background: linear-gradient(135deg, #7c3aed, #3b82f6); border: none;">
                                                Pay <t t-esc="currency_symbol"/><t t-esc="'%.2f' % total"/>
                                            </button>
                                        </form>
                                        <p class="text-muted text-center mt-3">
                                            <small>
                                                <i class="fa fa-lock me-1"/>
                                                Secure payment via SSLCommerz. Your data is protected.
                                            </small>
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Activation Status Page — live provisioning progress -->
    <template id="activation_status" name="Activation Status">
        <t t-call="website.layout">
            <div class="saas-prov-wrap">
                <div class="saas-prov-card">
                    <!-- BUILDING -->
                    <div id="prov-building">
                        <div class="saas-prov-spinner"/>
                        <h2 class="saas-prov-title">Setting up your workspace…</h2>
                        <p class="saas-prov-sub">
                            We're provisioning your private instance. This usually takes
                            <strong>2–3 minutes</strong>.
                        </p>
                        <t t-if="subscription.tenant_shortname">
                            <p class="saas-prov-addr">
                                Your address will be
                                <strong><t t-esc="subscription.tenant_shortname"/>.<t t-esc="base_domain or 'perfecthr.net'"/></strong>
                            </p>
                        </t>
                        <div class="saas-prov-bar"><div class="saas-prov-bar-fill"/></div>
                        <ul class="saas-prov-steps">
                            <li class="done"><span class="dot"/>Payment confirmed</li>
                            <li><span class="dot"/>Creating your database</li>
                            <li><span class="dot"/>Installing your apps</li>
                            <li><span class="dot"/>Securing your workspace</li>
                        </ul>
                        <p class="saas-prov-note">
                            <i class="fa fa-envelope-o me-1"/>You can safely leave this page — we'll email your
                            login details the moment it's ready.
                        </p>
                    </div>
                    <!-- READY -->
                    <div id="prov-ready" style="display:none;">
                        <div class="saas-prov-check"><i class="fa fa-check"/></div>
                        <h2 class="saas-prov-title">Your workspace is ready!</h2>
                        <p class="saas-prov-sub">Taking you to your access details…</p>
                    </div>
                    <!-- FAILED -->
                    <div id="prov-failed" style="display:none;">
                        <div class="saas-prov-fail"><i class="fa fa-exclamation-triangle"/></div>
                        <h2 class="saas-prov-title">Setup hit a snag</h2>
                        <p class="saas-prov-sub">
                            Don't worry — our team has been notified and we'll get your instance up shortly.
                        </p>
                        <a href="/my/subscriptions" class="saas-prov-btn">View My Subscriptions</a>
                    </div>
                </div>
            </div>

            <style>
                .saas-prov-wrap { min-height:70vh; display:flex; align-items:center; justify-content:center; background:#f7f8fc; padding:40px 16px; }
                .saas-prov-card { background:#fff; border:1px solid #e8ecf1; border-radius:18px; box-shadow:0 8px 30px rgba(0,0,0,0.06); max-width:520px; width:100%; padding:44px 36px; text-align:center; font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; }
                .saas-prov-spinner { width:64px; height:64px; margin:0 auto 22px; border-radius:50%; border:5px solid #eef2ff; border-top-color:#7c3aed; animation:saas-spin 0.9s linear infinite; }
                @keyframes saas-spin { to { transform:rotate(360deg); } }
                .saas-prov-title { font-size:1.6rem; font-weight:800; color:#1a1d2e; margin-bottom:8px; }
                .saas-prov-sub { color:#5f6980; margin-bottom:6px; }
                .saas-prov-addr { color:#5f6980; font-size:0.92rem; margin-bottom:6px; }
                .saas-prov-addr strong { color:#7c3aed; }
                .saas-prov-bar { height:8px; border-radius:8px; background:#eef2ff; overflow:hidden; margin:18px 0 26px; }
                .saas-prov-bar-fill { height:100%; width:40%; border-radius:8px; background:linear-gradient(90deg,#7c3aed,#3b82f6); animation:saas-indet 1.8s ease-in-out infinite; }
                @keyframes saas-indet { 0%{margin-left:-40%;} 100%{margin-left:100%;} }
                .saas-prov-steps { list-style:none; padding:0; margin:0 auto 22px; max-width:280px; text-align:left; }
                .saas-prov-steps li { display:flex; align-items:center; gap:10px; padding:7px 0; color:#8f96a8; font-size:0.92rem; font-weight:500; transition:color .3s; }
                .saas-prov-steps li .dot { width:12px; height:12px; border-radius:50%; border:2px solid #d5d9e2; flex-shrink:0; transition:all .3s; }
                .saas-prov-steps li.active { color:#1a1d2e; }
                .saas-prov-steps li.active .dot { border-color:#7c3aed; box-shadow:0 0 0 4px rgba(124,58,237,0.15); }
                .saas-prov-steps li.done { color:#1a1d2e; }
                .saas-prov-steps li.done .dot { background:#22c55e; border-color:#22c55e; }
                .saas-prov-note { color:#8f96a8; font-size:0.85rem; margin:0; }
                .saas-prov-check { width:72px; height:72px; margin:0 auto 20px; border-radius:50%; background:#f0fdf4; color:#22c55e; display:flex; align-items:center; justify-content:center; font-size:2rem; }
                .saas-prov-fail { width:72px; height:72px; margin:0 auto 20px; border-radius:50%; background:#fef2f2; color:#ef4444; display:flex; align-items:center; justify-content:center; font-size:2rem; }
                .saas-prov-btn { display:inline-block; margin-top:16px; padding:11px 24px; border-radius:10px; background:linear-gradient(135deg,#7c3aed,#3b82f6); color:#fff; font-weight:600; text-decoration:none; }
            </style>

            <script type="text/javascript">
                document.addEventListener('DOMContentLoaded', function () {
                    var subId = <t t-esc="subscription.id"/>;
                    var steps = Array.prototype.slice.call(document.querySelectorAll('.saas-prov-steps li'));
                    var cur = 1;
                    if (steps[1]) { steps[1].classList.add('active'); }
                    // Cosmetic step advancement so the customer sees steady motion.
                    var stepTimer = setInterval(function () {
                        if (cur &lt; steps.length - 1) {
                            steps[cur].classList.remove('active');
                            steps[cur].classList.add('done');
                            cur += 1;
                            steps[cur].classList.add('active');
                        }
                    }, 30000);
                    function finishAll() {
                        clearInterval(stepTimer);
                        steps.forEach(function (s) { s.classList.add('done'); s.classList.remove('active'); });
                    }
                    function poll() {
                        fetch('/saas/activation/status/' + subId + '/json')
                            .then(function (r) { return r.json(); })
                            .then(function (d) {
                                if (d.tenant_url &amp;&amp; d.tenant_url.length) {
                                    finishAll();
                                    document.getElementById('prov-building').style.display = 'none';
                                    document.getElementById('prov-ready').style.display = 'block';
                                    setTimeout(function () {
                                        window.location.href = '/saas/activation/complete/' + subId;
                                    }, 1500);
                                } else if (d.is_failed) {
                                    clearInterval(stepTimer);
                                    document.getElementById('prov-building').style.display = 'none';
                                    document.getElementById('prov-failed').style.display = 'block';
                                } else {
                                    setTimeout(poll, 4000);
                                }
                            })
                            .catch(function () { setTimeout(poll, 6000); });
                    }
                    setTimeout(poll, 3000);
                });
            </script>
        </t>
    </template>

    <!-- Activation Complete Page -->
    <template id="activation_complete" name="Activation Complete">
        <t t-call="website.layout">
            <div class="container mt-5">
                <div class="row justify-content-center">
                    <div class="col-md-8">
                        <div class="card text-center">
                            <div class="card-body p-5">
                                <span class="fa fa-check-circle fa-5x text-success mb-4"/>
                                <h2>Your SaaS Instance is Ready!</h2>
                                <p class="lead">Your instance has been successfully provisioned.</p>
                                
                                <div class="alert alert-info mt-4">
                                    <h5>Access Details:</h5>
                                    <p><strong>URL:</strong> <a t-attf-href="{{tenant_url}}" target="_blank"><t t-esc="tenant_url"/></a></p>
                                    <p><strong>Username:</strong> <t t-esc="subscription.partner_id.email or 'admin@saas.tenant'"/></p>
                                    <p><strong>Password:</strong> Check your email</p>
                                </div>
                                
                                <div class="mt-4">
                                    <a t-attf-href="{{tenant_url}}" target="_blank" class="btn btn-success btn-lg me-2">Launch Instance</a>
                                    <a href="/my/subscriptions" class="btn btn-outline-primary btn-lg">View My Subscriptions</a>
                                </div>
                                
                                <p class="text-muted mt-4">
                                    <small>We've also sent the credentials to your email address.</small>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
