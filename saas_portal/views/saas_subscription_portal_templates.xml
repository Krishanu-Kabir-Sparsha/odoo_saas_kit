<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Checkout Page -->
    <template id="checkout_page" name="Checkout">
        <t t-call="website.layout">
            <div class="container mt-4">
                <div class="row">
                    <div class="col-md-8 mx-auto">
                        <div class="card">
                            <div class="card-header">
                                <h3 class="mb-0">Checkout</h3>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-6">
                                        <h5>Order Summary</h5>
                                        <table class="table table-sm">
                                            <tr>
                                                <th><t t-esc="subscription.package_id.name"/> (<t t-esc="subscription.billing_cycle"/>)</th>
                                                <td class="text-end"><t t-esc="subtotal"/> <t t-esc="request.env.company.currency_id.symbol"/></td>
                                            </tr>
                                            <t t-if="setup_fee">
                                                <tr>
                                                    <th>Setup Fee</th>
                                                    <td class="text-end"><t t-esc="setup_fee"/> <t t-esc="request.env.company.currency_id.symbol"/></td>
                                                </tr>
                                            </t>
                                            <t t-if="points_discount">
                                                <tr class="text-success">
                                                    <th>Points Discount</th>
                                                    <td class="text-end">-<t t-esc="points_discount"/> <t t-esc="request.env.company.currency_id.symbol"/></td>
                                                </tr>
                                            </t>
                                            <tr class="fw-bold">
                                                <th>Total</th>
                                                <td class="text-end"><t t-esc="total"/> <t t-esc="request.env.company.currency_id.symbol"/></td>
                                            </tr>
                                        </table>
                                    </div>
                                    <div class="col-md-6">
                                        <t t-if="points_balance">
                                            <h5>Apply Points</h5>
                                            <form method="get" action="/saas/checkout">
                                                <div class="mb-3">
                                                    <div class="input-group">
                                                        <input type="number" name="redeem_points" class="form-control" 
                                                               placeholder="Points to redeem" min="100" t-att-max="points_balance" step="100"/>
                                                        <button type="submit" class="btn btn-outline-success">Apply</button>
                                                    </div>
                                                    <small class="form-text text-muted">
                                                        Available: <t t-esc="points_balance"/> points
                                                    </small>
                                                </div>
                                            </form>
                                            <hr/>
                                        </t>
                                        
                                        <form method="post" action="/saas/checkout/pay">
                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                            <input type="hidden" name="redeem_points_amount" t-att-value="redeemed_points"/>
                                            <button type="submit" class="btn btn-success btn-block btn-lg">
                                                Pay <t t-esc="total"/> <t t-esc="request.env.company.currency_id.symbol"/>
                                            </button>
                                        </form>
                                        <p class="text-muted text-center mt-3">
                                            <small>Secure payment via SSLCommerz. Your data is protected.</small>
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Activation Status Page -->
    <template id="activation_status" name="Activation Status">
        <t t-call="website.layout">
            <div class="container mt-5">
                <div class="row justify-content-center">
                    <div class="col-md-8 text-center">
                        <div id="status-loading">
                            <span class="fa fa-spinner fa-spin fa-3x text-primary mb-3"/>
                            <h3>Setting up your instance...</h3>
                            <p>This usually takes 1-3 minutes. Please wait.</p>
                        </div>
                        <div id="status-success" style="display:none;">
                            <span class="fa fa-check-circle fa-3x text-success mb-3"/>
                            <h3>Your instance is ready!</h3>
                            <p>Redirecting you now...</p>
                        </div>
                        <div id="status-failed" style="display:none;">
                            <span class="fa fa-exclamation-circle fa-3x text-danger mb-3"/>
                            <h3>Setup encountered an issue</h3>
                            <p>Our team has been notified. Please try again later or contact support.</p>
                            <a href="/my/subscriptions" class="btn btn-primary">View My Subscriptions</a>
                        </div>
                    </div>
                </div>
            </div>
            <script type="text/javascript">
                document.addEventListener('DOMContentLoaded', function() {
                    var subscriptionId = <t t-esc="subscription.id"/>;
                    function checkStatus() {
                        var xhr = new XMLHttpRequest();
                        xhr.open('GET', '/saas/activation/status/' + subscriptionId + '/json');
                        xhr.onload = function() {
                            if (xhr.status === 200) {
                                var data = JSON.parse(xhr.responseText);
                                if (data.state === 'active') {
                                    document.getElementById('status-loading').style.display = 'none';
                                    document.getElementById('status-success').style.display = 'block';
                                    if (data.tenant_url) {
                                        setTimeout(function() {
                                            window.location.href = '/saas/activation/complete/' + subscriptionId;
                                        }, 2000);
                                    }
                                } else if (data.state === 'provisioning_failed') {
                                    document.getElementById('status-loading').style.display = 'none';
                                    document.getElementById('status-failed').style.display = 'block';
                                } else {
                                    setTimeout(checkStatus, 3000);
                                }
                            } else {
                                setTimeout(checkStatus, 5000);
                            }
                        };
                        xhr.onerror = function() {
                            setTimeout(checkStatus, 5000);
                        };
                        xhr.send();
                    }
                    setTimeout(checkStatus, 2000);
                });
            </script>
        </t>
    </template>

    <!-- Activation Complete Page -->
    <template id="activation_complete" name="Activation Complete">
        <t t-call="website.layout">
            <div class="container mt-5">
                <div class="row justify-content-center">
                    <div class="col-md-8">
                        <div class="card text-center">
                            <div class="card-body p-5">
                                <span class="fa fa-check-circle fa-5x text-success mb-4"/>
                                <h2>Your SaaS Instance is Ready!</h2>
                                <p class="lead">Your instance has been successfully provisioned.</p>
                                
                                <div class="alert alert-info mt-4">
                                    <h5>Access Details:</h5>
                                    <p><strong>URL:</strong> <a t-attf-href="{{tenant_url}}" target="_blank"><t t-esc="tenant_url"/></a></p>
                                    <p><strong>Username:</strong> admin@saas.tenant</p>
                                    <p><strong>Password:</strong> Check your email</p>
                                </div>
                                
                                <div class="mt-4">
                                    <a t-attf-href="{{tenant_url}}" target="_blank" class="btn btn-success btn-lg me-2">Launch Instance</a>
                                    <a href="/my/subscriptions" class="btn btn-outline-primary btn-lg">View My Subscriptions</a>
                                </div>
                                
                                <p class="text-muted mt-4">
                                    <small>We've also sent the credentials to your email address.</small>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>