<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Search View (must be defined BEFORE action that references it) -->
    <record id="view_saas_subscription_search" model="ir.ui.view">
        <field name="name">saas.subscription.search</field>
        <field name="model">saas.subscription</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="package_id"/>
                <field name="tenant_db_name"/>
                
                <filter name="active_subs" string="Active" domain="[('state','=','active')]"/>
                <filter name="pending_subs" string="Pending" domain="[('state','=','pending')]"/>
                <filter name="suspended_subs" string="Suspended" domain="[('state','=','suspended')]"/>
                <filter name="canceled_subs" string="Canceled" domain="[('state','=','canceled')]"/>
                <filter name="trials" string="Free Trials" domain="[('is_trial','=',True)]"/>

                <separator/>
                <filter name="monthly" string="Monthly" domain="[('billing_cycle','=','monthly')]"/>
                <filter name="yearly" string="Yearly" domain="[('billing_cycle','=','yearly')]"/>
                
                <separator/>
                <filter name="overdue" string="Overdue Payment" domain="[('date_next_invoice','&lt;',context_today())]"/>
                
                <group expand="0" string="Group By">
                    <filter name="group_by_state" string="Status" context="{'group_by':'state'}"/>
                    <filter name="group_by_package" string="Package" context="{'group_by':'package_id'}"/>
                    <filter name="group_by_billing_cycle" string="Billing Cycle" context="{'group_by':'billing_cycle'}"/>
                    <filter name="group_by_partner" string="Customer" context="{'group_by':'partner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action Window -->
    <record id="action_saas_subscription" model="ir.actions.act_window">
        <field name="name">Subscriptions</field>
        <field name="res_model">saas.subscription</field>
        <field name="view_mode">list,kanban,form,pivot,graph</field>
        <field name="search_view_id" ref="view_saas_subscription_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first subscription!
            </p>
            <p>
                Manage customer subscriptions, track state changes, and monitor billing.
            </p>
        </field>
    </record>
    
    <!-- Action Window for Creating New Subscription -->
    <record id="action_saas_subscription_create" model="ir.actions.act_window">
        <field name="name">Create Subscription</field>
        <field name="res_model">saas.subscription</field>
        <field name="view_mode">form,list</field>
        <field name="target">current</field>
        <field name="context">{'form_view_initial_mode': 'edit'}</field>
    </record>

    <!-- Tree View -->
    <record id="view_saas_subscription_tree" model="ir.ui.view">
        <field name="name">saas.subscription.tree</field>
        <field name="model">saas.subscription</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="package_id"/>
                <field name="billing_plan_label" string="Billing Plan"/>
                <field name="duration_months" optional="hide"/>
                <field name="billing_cycle" widget="badge" optional="hide"/>
                <field name="state" widget="badge" decoration-danger="state in ['suspended','canceled','rejected']"
                        decoration-success="state=='active'"
                        decoration-warning="state=='pending'"/>
                <field name="is_trial" optional="show"/>
                <field name="tenant_url"/>
                <field name="date_start"/>
                <field name="date_next_invoice" decoration-danger="date_next_invoice &lt; context_today()"/>
            </list>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_saas_subscription_kanban" model="ir.ui.view">
        <field name="name">saas.subscription.kanban</field>
        <field name="model">saas.subscription</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="package_id"/>
                <field name="state"/>
                <field name="billing_cycle"/>
                <field name="date_next_invoice"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_glib">
                            <div class="o_dropdown_kanban dropdown">
                                <a class="dropdown-toggle btn" data-toggle="dropdown" href="#">
                                    <span class="fa fa-ellipsis-v"/>
                                </a>
                                <ul class="dropdown-menu" role="menu">
                                    <li><a type="open">Open</a></li>
                                    <t t-if="record.state.raw_value == 'active'">
                                        <li><a name="action_suspend" type="object">Suspend</a></li>
                                    </t>
                                    <t t-if="record.state.raw_value == 'suspended'">
                                        <li><a name="action_activate" type="object">Activate</a></li>
                                    </t>
                                    <li><a name="action_cancel" type="object">Cancel</a></li>
                                </ul>
                            </div>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div class="text-muted o_kanban_record_subtitle">
                                    <field name="partner_id"/>
                                </div>
                                <div>
                                    <field name="package_id"/>
                                    <span class="badge" t-attf-class="#{record.billing_cycle.raw_value == 'yearly' ? 'badge-success' : 'badge-info'}">
                                        <field name="billing_cycle"/>
                                    </span>
                                </div>
                                <div>
                                    State: <field name="state" widget="badge"/>
                                </div>
                                <div t-if="record.date_next_invoice.raw_value">
                                    Next Invoice: <field name="date_next_invoice"/>
                                </div>
                                <div class="o_kanban_secondary_info mt-2">
                                    <field name="tenant_url"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_saas_subscription_form" model="ir.ui.view">
        <field name="name">saas.subscription.form</field>
        <field name="model">saas.subscription</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <!-- State buttons - Odoo 18 uses invisible= instead of states= -->
                    <button name="action_confirm" type="object" string="Confirm" 
                            class="btn-primary" invisible="state != 'draft'"
                            confirm="Confirm this subscription? This will create a sale order."/>
                    <button name="action_pay_now" type="object" string="Pay Now" 
                            class="btn-success" invisible="state != 'pending'"
                            help="Proceed to payment gateway to complete payment"/>
                    <button name="action_activate" type="object" string="Activate" 
                            class="btn-primary" invisible="state not in ('pending','suspended','provisioning_failed')"
                            confirm="Activate this subscription? Tenant will be provisioned."/>
                    <button name="action_suspend" type="object" string="Suspend" 
                            class="btn-danger" invisible="state != 'active'"
                            confirm="Suspend this subscription? Tenant access will be blocked."/>
                    <button name="action_cancel" type="object" string="Cancel" 
                            class="btn-danger" invisible="state not in ('active','suspended','pending','draft','provisioning_failed')"
                            confirm="Cancel this subscription? Tenant data will be scheduled for deletion."/>
                    <button name="action_reject" type="object" string="Reject" 
                            class="btn-danger" invisible="state != 'pending'"
                            confirm="Reject this subscription? This action cannot be undone."/>
                    <button name="action_retry_provisioning" type="object" string="Retry Provisioning" 
                            class="btn-secondary" invisible="state != 'provisioning_failed'"/>
                    
                    <field name="state" widget="statusbar" statusbar_visible="draft,pending,active,suspended"/>
                </header>
                
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_invoices" type="object" 
                                class="oe_stat_button" icon="fa-file-invoice"
                                help="View Invoices">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Invoices</span>
                            </div>
                        </button>
                    </div>
                    
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                        <div class="text-muted">
                            <field name="display_name" invisible="1"/>
                        </div>
                    </div>
                    
                    <group name="main_info">
                        <group>
                            <field name="partner_id" options="{'no_create': True}"/>
                            <field name="package_id"/>
                            <field name="billing_plan_label"/>
                            <field name="duration_months"/>
                            <field name="billing_cycle"/>
                        </group>
                        <group>
                            <field name="date_start"/>
                            <field name="date_next_invoice" 
                                   readonly="state in ('canceled','rejected')"/>
                            <field name="date_end"/>
                        </group>
                    </group>
                    
                    <group name="state_info" string="Status Information">
                        <group>
                            <field name="state"/>
                            <field name="state_reason" placeholder="Reason for current state"/>
                        </group>
                        <group>
                            <field name="date_suspended"/>
                            <field name="date_canceled"/>
                        </group>
                    </group>

                    <group name="plan_trial" string="Plan &amp; Trial">
                        <group>
                            <field name="is_trial"/>
                            <field name="trial_end_date" invisible="not is_trial"/>
                            <field name="trial_days_left" invisible="not is_trial"/>
                        </group>
                        <group>
                            <field name="upgrade_target_package_id"/>
                            <field name="module_sync_pending"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Tenant Information">
                            <group>
                                <group>
                                    <field name="tenant_db_name"/>
                                    <field name="tenant_url" widget="url"/>
                                </group>
                                <group>
                                    <field name="provisioned_at"/>
                                    <field name="provision_attempts"/>
                                </group>
                            </group>
                        </page>
                        
                        <page string="Billing &amp; Payment">
                            <group>
                                <group>
                                    <field name="sale_order_id"/>
                                    <field name="payment_gateway"/>
                                </group>
                                <group>
                                    <field name="invoice_ids" widget="many2many">
                                        <list>
                                            <field name="name"/>
                                            <field name="invoice_date"/>
                                            <field name="amount_total"/>
                                            <field name="payment_state" widget="badge"/>
                                        </list>
                                    </field>
                                </group>
                            </group>
                        </page>
                        
                        <page string="Points">
                            <group>
                                <group>
                                    <field name="points_earned_total"/>
                                    <field name="points_redeemed_total"/>
                                </group>
                                <group>
                                    <field name="points_balance"/>
                                </group>
                            </group>
                        </page>
                        
                        <page string="Logs">
                            <field name="log_ids" readonly="1">
                                <list>
                                    <field name="timestamp"/>
                                    <field name="user_id"/>
                                    <field name="from_state"/>
                                    <field name="to_state"/>
                                    <field name="reason"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="view_saas_subscription_pivot" model="ir.ui.view">
        <field name="name">saas.subscription.pivot</field>
        <field name="model">saas.subscription</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="state" type="row"/>
                <field name="package_id" type="col"/>
                <field name="date_start" interval="month" type="col"/>
                <field name="name" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Graph View -->
    <record id="view_saas_subscription_graph" model="ir.ui.view">
        <field name="name">saas.subscription.graph</field>
        <field name="model">saas.subscription</field>
        <field name="arch" type="xml">
            <graph>
                <field name="date_start" type="row"/>
                <field name="state" type="col"/>
                <field name="name" type="measure"/>
            </graph>
        </field>
    </record>
</odoo>