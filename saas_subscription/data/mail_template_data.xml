<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Template: Tenant Credentials -->
        <record id="email_template_tenant_credentials" model="mail.template">
            <field name="name">SaaS Tenant: Credentials</field>
            <field name="model_id" ref="saas_subscription.model_saas_subscription"/>
            <field name="subject">Your SaaS Instance is Ready! — {{ object.name }}</field>
            <field name="email_from">{{ (object.company_id.email or user.email) or '' }}</field>
            <field name="email_to">{{ object.partner_id.email }}</field>
            <field name="lang">{{ object.partner_id.lang }}</field>
            <field name="body_html" type="html">
                <div style="font-family: Arial, sans-serif; max-width: 600px;">
                    <h2>Welcome to <t t-out="object.package_id.name or ''"/>!</h2>
                    <p>Dear <t t-out="object.partner_id.name or ''"/>,</p>
                    <p>Your SaaS instance has been successfully provisioned and is ready for use.</p>

                    <h3>Access Details</h3>
                    <ul>
                        <li><strong>URL:</strong>
                            <a t-attf-href="https://{{ ctx.get('tenant_domain') }}">
                                <t t-out="ctx.get('tenant_domain') or ''"/>
                            </a>
                        </li>
                        <li><strong>Username:</strong> <t t-out="object.partner_id.email or 'admin@saas.tenant'"/></li>
                        <li><strong>Password:</strong> <code t-out="ctx.get('admin_password') or ''"/></li>
                    </ul>

                    <div style="background-color:#fff3cd;padding:10px;border-radius:5px;margin:15px 0;">
                        <strong>⚠ Important</strong>
                        <ul style="margin:5px 0;">
                            <li>Save this password — you'll need it to access your instance.</li>
                            <li>You can change your password after first login.</li>
                            <li>Your billing cycle started on <t t-out="object.date_start"/>.</li>
                        </ul>
                    </div>

                    <p>
                        <a t-attf-href="https://{{ ctx.get('tenant_domain') }}"
                           style="background-color:#4CAF50;color:white;padding:10px 20px;text-decoration:none;border-radius:5px;display:inline-block;">
                            Access Your Instance
                        </a>
                    </p>

                    <hr style="margin:20px 0;"/>
                    <p style="color:#666;font-size:12px;">Need help? Reply to this email.</p>
                </div>
            </field>
            <field name="auto_delete" eval="False"/>
        </record>
    </data>
</odoo>
