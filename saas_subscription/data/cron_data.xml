<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Provisioning executor / retry cron.
         Kept updateable (noupdate="0") so the corrected model reference and
         settings deploy on module upgrade. This cron is also triggered
         on-demand (immediately after activation) via _trigger(). -->
    <data noupdate="0">
        <record id="cron_retry_failed_provisioning" model="ir.cron">
            <field name="name">SaaS: Provision / Retry Tenants</field>
            <field name="model_id" ref="model_subscription_cron"/>
            <field name="state">code</field>
            <field name="code">model._cron_retry_failed_provisioning()</field>
            <field name="interval_number">10</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
        </record>

        <!-- Plan upgrade: install the new tier's apps into existing tenants.
             Triggered immediately after an upgrade (_trigger); this interval is
             the backstop that retries any that didn't finish. -->
        <record id="cron_sync_tenant_modules" model="ir.cron">
            <field name="name">SaaS: Sync Upgraded Tenant Apps</field>
            <field name="model_id" ref="model_tenant_provisioner"/>
            <field name="state">code</field>
            <field name="code">model._cron_sync_tenant_modules()</field>
            <field name="interval_number">15</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
        </record>

        <!-- Refresh the in-tenant dashboard snapshot (plan / status / renewal /
             days-left) for every provisioned tenant. Storage usage is computed
             live in-tenant; this keeps the master-owned facts current. -->
        <record id="cron_refresh_tenant_snapshots" model="ir.cron">
            <field name="name">SaaS: Refresh Tenant Dashboard Snapshots</field>
            <field name="model_id" ref="model_saas_subscription"/>
            <field name="state">code</field>
            <field name="code">model._cron_refresh_tenant_snapshots()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>

        <!-- Free trial expiry: suspend tenants whose trial ended without payment. -->
        <record id="cron_expire_trials" model="ir.cron">
            <field name="name">SaaS: Expire Free Trials</field>
            <field name="model_id" ref="model_saas_subscription"/>
            <field name="state">code</field>
            <field name="code">model._cron_expire_trials()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>
    </data>

    <data noupdate="1">
        <!-- Cron: Auto-cancel suspended subscriptions -->
        <record id="cron_auto_cancel_suspended" model="ir.cron">
            <field name="name">Auto-Cancel Suspended Subscriptions</field>
            <field name="model_id" ref="model_saas_subscription_auto_expire"/>
            <field name="state">code</field>
            <field name="code">model._auto_cancel_suspended_subscriptions()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>

        <!-- Cron: Cleanup old logs -->
        <record id="cron_cleanup_old_logs" model="ir.cron">
            <field name="name">Cleanup Old Subscription Logs</field>
            <field name="model_id" ref="model_subscription_cron"/>
            <field name="state">code</field>
            <field name="code">model._cron_cleanup_old_logs()</field>
            <field name="interval_number">7</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>
