<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron: Retry failed provisioning -->
        <record id="cron_retry_failed_provisioning" model="ir.cron">
            <field name="name">Retry Failed SaaS Provisioning</field>
            <field name="model_id" ref="model_tenant_provisioner"/>
            <field name="state">code</field>
            <field name="code">model._cron_retry_failed_provisioning()</field>
            <field name="interval_number">30</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
        </record>

        <!-- Cron: Auto-cancel suspended subscriptions -->
        <record id="cron_auto_cancel_suspended" model="ir.cron">
            <field name="name">Auto-Cancel Suspended Subscriptions</field>
            <field name="model_id" ref="model_saas_subscription_auto_expire"/>
            <field name="state">code</field>
            <field name="code">model._auto_cancel_suspended_subscriptions()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>

        <!-- Cron: Cleanup old logs -->
        <record id="cron_cleanup_old_logs" model="ir.cron">
            <field name="name">Cleanup Old Subscription Logs</field>
            <field name="model_id" ref="model_subscription_cron"/>
            <field name="state">code</field>
            <field name="code">model._cron_cleanup_old_logs()</field>
            <field name="interval_number">7</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>