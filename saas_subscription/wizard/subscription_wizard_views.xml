<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_subscription_change_package_wizard_form" model="ir.ui.view">
        <field name="name">subscription.change.package.wizard.form</field>
        <field name="model">subscription.change.package.wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="subscription_id" invisible="1"/>
                        <field name="new_package_id" required="1"/>
                        <field name="effective_date" required="1"/>
                        <field name="reason"/>
                    </group>
                    <footer>
                        <button name="action_confirm" type="object" string="Confirm Change" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>
</odoo>