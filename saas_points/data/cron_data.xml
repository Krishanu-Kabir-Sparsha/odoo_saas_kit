<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron: Expire old points -->
        <record id="cron_expire_points" model="ir.cron">
            <field name="name">Expire Old SaaS Points</field>
            <field name="model_id" ref="model_saas_points_transaction"/>
            <field name="state">code</field>
            <field name="code">model._cron_expire_points()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(hours=1)).strftime('%Y-%m-%d 01:00:00')"/>

            <field name="active">True</field>
        </record>
    </data>
</odoo>