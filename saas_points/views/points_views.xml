<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>
    <record id="view_saas_points_transaction_tree" model="ir.ui.view">
        <field name="name">saas.points.transaction.tree</field>
        <field name="model">saas.points.transaction</field>
        <field name="arch" type="xml">
            <list>
                <field name="date"/>
                <field name="partner_id"/>
                <field name="subscription_id"/>
                <field name="transaction_type" widget="badge"
                       decoration-success="transaction_type == 'earn'"
                       decoration-danger="transaction_type == 'expire'"
                       decoration-warning="transaction_type == 'redeem'"/>
                <field name="points"/>
                <field name="expiry_date"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <!-- Points Transaction Form View -->
    <record id="view_saas_points_transaction_form" model="ir.ui.view">
        <field name="name">saas.points.transaction.form</field>
        <field name="model">saas.points.transaction</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="subscription_id"/>
                            <field name="invoice_id"/>
                        </group>
                        <group>
                            <field name="transaction_type"/>
                            <field name="points"/>
                            <field name="date"/>
                            <field name="expiry_date" invisible="transaction_type != 'earn'"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Points Configuration Form -->
    <record id="view_saas_points_config_form" model="ir.ui.view">
        <field name="name">saas.points.config.form</field>
        <field name="model">saas.points.config</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="alert alert-info">
                        <strong>Points System Configuration</strong><br/>
                        Configure how loyalty points are earned and redeemed.
                    </div>
                    <group>
                        <group string="Earning Rules">
                            <field name="points_multiplier" 
                                   help="Points earned = Invoice Subtotal × Multiplier"/>
                            <field name="points_expiry_months" 
                                   help="Points expire after this many months"/>
                        </group>
                        <group string="Redemption Rules">
                            <field name="min_points_redemption" 
                                   help="Minimum points required to redeem"/>
                            <field name="points_value_per_unit" 
                                   help="Monetary value of 1 point"/>
                            <field name="max_discount_percent" 
                                   help="Maximum discount as % of invoice total"/>
                        </group>
                    </group>
                    <footer>
                        <button name="action_save_config" type="object" string="Save" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_saas_points_transaction" model="ir.actions.act_window">
        <field name="name">Points Transactions</field>
        <field name="res_model">saas.points.transaction</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_saas_points_config" model="ir.actions.act_window">
        <field name="name">Points Configuration</field>
        <field name="res_model">saas.points.config</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menus -->
    <menuitem id="menu_saas_points" name="Loyalty Points" parent="saas_package.menu_saas_root" sequence="40" groups="saas_package.group_saas_manager"/>
    <menuitem id="menu_saas_points_transactions" name="Transactions" parent="menu_saas_points" action="action_saas_points_transaction" sequence="10"/>
    <menuitem id="menu_saas_points_config_menu" name="Configuration" parent="menu_saas_points" action="action_saas_points_config" sequence="20"/>
</data>

    <!-- Portal Template -->
    <template id="portal_my_points" name="My Points">
        <t t-call="portal.portal_layout">
            <div class="container">
                <div class="row">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-header">
                                <h3>My Loyalty Points</h3>
                            </div>
                            <div class="card-body">
                                <div class="row mb-4">
                                    <div class="col-md-4">
                                        <div class="text-center p-3 bg-info text-white rounded">
                                            <h2><t t-esc="points_balance"/></h2>
                                            <p>Available Points</p>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="text-center p-3 bg-success text-white rounded">
                                            <h2><t t-esc="points_value"/> <small><t t-esc="currency_symbol"/></small></h2>
                                            <p>Approximate Value</p>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="text-center p-3 bg-warning text-white rounded">
                                            <h2><t t-esc="min_points"/></h2>
                                            <p>Minimum to Redeem</p>
                                        </div>
                                    </div>
                                </div>
                                
                                <h4 class="mt-4">Transaction History</h4>
                                <table class="table table-striped">
                                    <thead>
                                        <tr>
                                            <th>Date</th>
                                            <th>Type</th>
                                            <th>Points</th>
                                            <th>Description</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="transactions" t-as="trans">
                                            <td><t t-esc="trans.date"/></td>
                                            <td><t t-esc="trans.transaction_type"/></td>
                                            <td><t t-esc="trans.points"/></td>
                                            <td><t t-esc="trans.description"/></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>